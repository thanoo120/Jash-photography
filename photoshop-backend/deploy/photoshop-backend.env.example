# Copy to /opt/photoshop/photoshop-backend.env (chmod 600, owned by root).
# Replace placeholders before starting the service.

SPRING_PROFILES_ACTIVE=prod

# App listens on 8090 by default (matches server.port in application.properties).
# SERVER_PORT=8090

# RDS MySQL — create DB and user in RDS console first.
SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_RDS_ENDPOINT.ap-south-1.rds.amazonaws.com:3306/YOUR_DB_NAME?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=REPLACE_ME

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Frontend origins (HTTPS), comma-separated, no spaces.
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: one-time first admin when the DB has no ROLE_ADMIN yet (see deploy/README-DEPLOY.md).
# After first successful login, set APP_BOOTSTRAP_ADMIN_ENABLED=false and restart.
# APP_BOOTSTRAP_ADMIN_ENABLED=false
# APP_BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
# APP_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
